# Use either the legacy anon JWT or the new publishable key (Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

NEXT_PUBLIC_ADMIN_PIN=admin1234

